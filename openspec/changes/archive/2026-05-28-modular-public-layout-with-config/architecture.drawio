<mxfile host="app.diagrams.net" agent="C4 Diagram Skill" version="24.0.0" type="device">
  <diagram id="c4-container" name="C4 Container Diagram">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- LAYER 1: Person -->
        <mxCell id="person_browser"
          value=""
          style="shape=actor;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#052E56;"
          vertex="1" parent="1">
          <mxGeometry x="850" y="25" width="40" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="person_browser_label"
          value="&lt;b&gt;School Visitor / Admin&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#666666&quot;&gt;[Person]&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#666666&quot;&gt;Views public pages or manages content via browser.&lt;/font&gt;"
          style="text;html=1;fontSize=12;align=center;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="760" y="93" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- LAYER 2: System Boundary -->
        <mxCell id="boundary_1"
          value="Open School CMS [Software System]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#444444;strokeWidth=2;dashed=1;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;fontColor=#444444;"
          vertex="1" parent="1">
          <mxGeometry x="50" y="175" width="1700" height="780" as="geometry"/>
        </mxCell>

        <!-- Row 1: Page Assembler, Admin Panel -->
        <mxCell id="container_page_assembler"
          value="&lt;b&gt;index.php / page.php&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: PHP 8.0+]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Assembles public pages; requires header &amp;amp; footer; queries DB for dynamic content.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=13;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="560" y="260" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="container_admin"
          value="&lt;b&gt;Admin Panel&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: PHP 8.0+]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Manages menus, slides, news, blocks; writes config.json for branding.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=13;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="1260" y="260" width="240" height="120" as="geometry"/>
        </mxCell>

        <!-- Row 2: header.php, config.php (cfg helper), footer.php -->
        <mxCell id="container_header"
          value="&lt;b&gt;includes/header.php&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: PHP Include]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Renders HTML head, school banner, CSS vars, and primary nav menu.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=13;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="180" y="455" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="container_config_php"
          value="&lt;b&gt;includes/config.php&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: PHP Helper]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;cfg() — dot-notation access to config.json; cached in memory per request.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=13;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="560" y="455" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="container_footer"
          value="&lt;b&gt;includes/footer.php&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: PHP Include]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Renders footer chrome with quick links, contact info, and copyright.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=13;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="940" y="455" width="240" height="120" as="geometry"/>
        </mxCell>

        <!-- Row 3: carousel/, config/ JSON, MySQL DB -->
        <mxCell id="container_carousel"
          value="&lt;b&gt;assets/img/carousel/&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: File Folder]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;JPEG/PNG slides auto-discovered via glob(). Drop a file = new slide.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=13;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="180" y="670" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="container_config_json"
          value="&lt;b&gt;config/ JSON Files&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: JSON Config]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;config.json, menu.json, home.json, external_links.json — deployer-edited identity &amp;amp; static content.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=13;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="560" y="670" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="db_mysql"
          value="&lt;b&gt;MySQL Database&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: MySQL 5.7+]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Runtime content: menus, hero slides, news, content blocks, popular links.&lt;/font&gt;"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=13;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="1260" y="670" width="240" height="120" as="geometry"/>
        </mxCell>

        <!-- CONNECTIONS -->

        <!-- Browser → Page Assembler -->
        <mxCell id="conn_browser_page"
          value="Views public pages [HTTP]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="person_browser" target="container_page_assembler" parent="1">
          <mxGeometry y="-10" relative="1" as="geometry"/>
        </mxCell>

        <!-- Browser → Admin Panel -->
        <mxCell id="conn_browser_admin"
          value="Manages content [HTTP]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="person_browser" target="container_admin" parent="1">
          <mxGeometry y="-15" relative="1" as="geometry"/>
        </mxCell>

        <!-- Page Assembler → header.php -->
        <mxCell id="conn_page_header"
          value="require_once [PHP]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="container_page_assembler" target="container_header" parent="1">
          <mxGeometry y="-10" relative="1" as="geometry"/>
        </mxCell>

        <!-- Page Assembler → footer.php -->
        <mxCell id="conn_page_footer"
          value="require_once [PHP]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="container_page_assembler" target="container_footer" parent="1">
          <mxGeometry y="-10" relative="1" as="geometry"/>
        </mxCell>

        <!-- Page Assembler → config.php -->
        <mxCell id="conn_page_cfgphp"
          value="calls cfg() [PHP]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="container_page_assembler" target="container_config_php" parent="1">
          <mxGeometry y="10" relative="1" as="geometry"/>
        </mxCell>

        <!-- header.php → config.php -->
        <mxCell id="conn_header_cfgphp"
          value="calls cfg() [PHP]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="container_header" target="container_config_php" parent="1">
          <mxGeometry y="-12" relative="1" as="geometry"/>
        </mxCell>

        <!-- footer.php → config.php -->
        <mxCell id="conn_footer_cfgphp"
          value="calls cfg() [PHP]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="container_footer" target="container_config_php" parent="1">
          <mxGeometry y="12" relative="1" as="geometry"/>
        </mxCell>

        <!-- config.php → config/ JSON -->
        <mxCell id="conn_cfgphp_json"
          value="reads files [file I/O]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="container_config_php" target="container_config_json" parent="1">
          <mxGeometry y="10" relative="1" as="geometry"/>
        </mxCell>

        <!-- Page Assembler → carousel/ [dashed, file I/O] -->
        <mxCell id="conn_page_carousel"
          value="glob() scans images [file I/O]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;dashed=1;dashPattern=5 5;labelBackgroundColor=#ffffff;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="container_page_assembler" target="container_carousel" parent="1">
          <mxGeometry y="-10" relative="1" as="geometry"/>
        </mxCell>

        <!-- Page Assembler → MySQL DB (routed above boundary via waypoints) -->
        <mxCell id="conn_page_mysql"
          value="PDO queries [SQL]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;"
          edge="1" source="container_page_assembler" target="db_mysql" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="220"/>
              <mxPoint x="1380" y="220"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Admin Panel → MySQL DB (straight down, same column) -->
        <mxCell id="conn_admin_mysql"
          value="PDO queries [SQL]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="container_admin" target="db_mysql" parent="1">
          <mxGeometry y="10" relative="1" as="geometry"/>
        </mxCell>

        <!-- Admin Panel → config/ JSON [dashed, writes; routed below all rows] -->
        <mxCell id="conn_admin_cfgjson"
          value="writes config.json [file I/O]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;dashed=1;dashPattern=5 5;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;"
          edge="1" source="container_admin" target="container_config_json" parent="1">
