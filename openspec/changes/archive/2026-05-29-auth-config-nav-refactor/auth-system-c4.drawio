<mxfile host="app.diagrams.net" agent="C4 Diagram Skill" version="24.0.0" type="device">
  <diagram id="c4-auth" name="C4 Container - Auth System">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ======================================== -->
        <!-- LAYER 1: Person                          -->
        <!-- ======================================== -->

        <mxCell id="person_1"
          value=""
          style="shape=actor;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#052E56;"
          vertex="1" parent="1">
          <mxGeometry x="760" y="20" width="40" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="person_1_label"
          value="&lt;b&gt;Admin User&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#666666&quot;&gt;[Person]&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;color:#666666&quot;&gt;School administrator or SA.&lt;/font&gt;"
          style="text;html=1;fontSize=12;align=center;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="650" y="84" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- ======================================== -->
        <!-- LAYER 2: System Boundary                 -->
        <!-- ======================================== -->

        <mxCell id="boundary_1"
          value="IRM Admin System [Software System]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#444444;strokeWidth=2;dashed=1;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;fontColor=#444444;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="1500" height="490" as="geometry"/>
        </mxCell>

        <!-- Login Page -->
        <mxCell id="container_1"
          value="&lt;b&gt;Login Page&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: PHP]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Homegrown form + SSO button when provider is active.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=14;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="240" height="120" as="geometry"/>
        </mxCell>

        <!-- OIDC Redirect Handler -->
        <mxCell id="container_2"
          value="&lt;b&gt;OIDC Redirect Handler&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: PHP]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Builds authorization URL; sets state &amp;amp; nonce in session.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=14;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="390" y="280" width="240" height="120" as="geometry"/>
        </mxCell>

        <!-- OIDC Callback (Placeholder) -->
        <mxCell id="container_3"
          value="&lt;b&gt;OIDC Callback&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: PHP — Placeholder]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Receives auth code from provider. Not yet implemented.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=14;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="700" y="280" width="240" height="120" as="geometry"/>
        </mxCell>

        <!-- Protected Admin Pages -->
        <mxCell id="container_4"
          value="&lt;b&gt;Protected Admin Pages&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: PHP]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Dashboard, profile, auth config, users. Guarded by require_auth().&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=14;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="1100" y="280" width="240" height="120" as="geometry"/>
        </mxCell>

        <!-- MySQL Database -->
        <mxCell id="db_1"
          value="&lt;b&gt;MySQL Database&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Container: MySQL]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;auth_users &amp;amp; auth_config tables.&lt;/font&gt;"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#438DD5;fontColor=#ffffff;strokeColor=none;fontSize=14;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="1100" y="470" width="240" height="120" as="geometry"/>
        </mxCell>

        <!-- ======================================== -->
        <!-- LAYER 3: External Systems                -->
        <!-- ======================================== -->

        <mxCell id="ext_1"
          value="&lt;b&gt;OIDC / SAML Provider&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[External System]&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Identity provider (e.g. Okta, Google). Issues auth codes.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;container=0;fillColor=#999999;fontColor=#ffffff;strokeColor=none;fontSize=14;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="480" y="800" width="280" height="120" as="geometry"/>
        </mxCell>

        <!-- ======================================== -->
        <!-- CONNECTIONS                               -->
        <!-- ======================================== -->

        <!-- 1. Admin User → Login Page -->
        <mxCell id="conn_1"
          value="Logs in [HTTPS]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="person_1" target="container_1" parent="1">
          <mxGeometry y="-15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- 2. Login Page → OIDC Redirect Handler -->
        <mxCell id="conn_2"
          value="Initiates SSO [HTTP/302]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="container_1" target="container_2" parent="1">
          <mxGeometry y="-15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- 3. OIDC Redirect Handler → OIDC/SAML Provider -->
        <mxCell id="conn_3"
          value="Redirects to authorization endpoint [HTTPS/302]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="container_2" target="ext_1" parent="1">
          <mxGeometry y="-15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- 4. OIDC/SAML Provider → OIDC Callback -->
        <mxCell id="conn_4"
          value="Returns auth code [HTTPS/302]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;"
          edge="1" source="ext_1" target="container_3" parent="1">
          <mxGeometry y="15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- 5. Login Page → Protected Admin Pages (homegrown success, routed over top) -->
        <mxCell id="conn_5"
          value="Sets session &amp; redirects after login [HTTP/302]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;rounded=1;"
          edge="1" source="container_1" target="container_4" parent="1">
          <mxGeometry y="-15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- 6. OIDC Callback → Protected Admin Pages (placeholder — dashed) -->
        <mxCell id="conn_6"
          value="Future: sets session &amp; redirects [HTTP/302]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;dashed=1;dashPattern=5 5;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="container_3" target="container_4" parent="1">
          <mxGeometry y="-15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- 7. Login Page → MySQL DB -->
        <mxCell id="conn_7"
          value="Verifies credentials &amp; reads auth_config [SQL/TCP]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;"
          edge="1" source="container_1" target="db_1" parent="1">
          <mxGeometry y="15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- 8. OIDC Redirect Handler → MySQL DB -->
        <mxCell id="conn_8"
          value="Reads provider config [SQL/TCP]"
          style="endArrow=blockThin;endFill=1;fontSize=10;fontColor=#404040;strokeColor=#404040;labelBackgroundColor=#ffffff;"
          edge="1" source="container_2" target="db_1" parent="1">
          <mxGeometry y="15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- 9. Protected Admin Pages → MySQL DB -->
        <mxCell id="conn_9"
