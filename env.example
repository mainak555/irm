# Copy this file to `.env` and fill in your values.
# NEVER commit the real .env to version control.

# ---- Database (MySQL / MariaDB) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=irm
DB_USER=root
DB_PASS=change-me

# ---- Application ----
# Generate a long random string: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=change-me-to-a-long-random-string

# Set to "true" only on local development machines
APP_DEBUG=false
